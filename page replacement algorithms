#include <stdio.h>

int main() {
    int pages[50], frames[10];
    int n, f, choice;
    int i, j, k;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    printf("Enter page reference string: ");
    for(i = 0; i < n; i++)
        scanf("%d", &pages[i]);

    printf("Enter number of frames: ");
    scanf("%d", &f);

    printf("\nPage Replacement Algorithms");
    printf("\n1. FIFO");
    printf("\n2. LRU");
    printf("\n3. Optimal");
    printf("\nEnter your choice: ");
    scanf("%d", &choice);

    switch(choice) {

    // FIFO
    case 1: {
        int faults = 0;
        int found;
        int ptr = 0;

        for(i = 0; i < f; i++)
            frames[i] = -1;

        for(i = 0; i < n; i++) {
            found = 0;

            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    found = 1;
                    break;
                }
            }

            if(!found) {
                frames[ptr] = pages[i];
                ptr = (ptr + 1) % f;
                faults++;
            }
        }

        printf("\nFIFO Page Faults = %d\n", faults);
        break;
    }

    // LRU
    case 2: {
        int faults = 0;
        int found;
        int time[10], counter = 0;
        int min, pos;

        for(i = 0; i < f; i++) {
            frames[i] = -1;
            time[i] = 0;
        }

        for(i = 0; i < n; i++) {
            found = 0;

            // Check for hit
            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    counter++;
                    time[j] = counter;
                    found = 1;
                    break;
                }
            }

            if(!found) {

                // Check for empty frame
                pos = -1;

                for(j = 0; j < f; j++) {
                    if(frames[j] == -1) {
                        pos = j;
                        break;
                    }
                }

                // If no empty frame, find LRU page
                if(pos == -1) {
                    min = time[0];
                    pos = 0;

                    for(j = 1; j < f; j++) {
                        if(time[j] < min) {
                            min = time[j];
                            pos = j;
                        }
                    }
                }

                frames[pos] = pages[i];
                counter++;
                time[pos] = counter;
                faults++;
            }
        }

        printf("\nLRU Page Faults = %d\n", faults);
        break;
    }

    // Optimal
    case 3: {
        int faults = 0, found;
        int pos, farthest, index;

        for(i = 0; i < f; i++)
            frames[i] = -1;

        for(i = 0; i < n; i++) {
            found = 0;

            // Check hit
            for(j = 0; j < f; j++) {
                if(frames[j] == pages[i]) {
                    found = 1;
                    break;
                }
            }

            if(!found) {

                // Check for empty frame
                pos = -1;

                for(j = 0; j < f; j++) {
                    if(frames[j] == -1) {
                        pos = j;
                        break;
                    }
                }

                // If no empty frame, apply Optimal
                if(pos == -1) {

                    farthest = -1;
                    pos = 0;

                    for(j = 0; j < f; j++) {

                        index = n;

                        for(k = i + 1; k < n; k++) {
                            if(frames[j] == pages[k]) {
                                index = k;
                                break;
                            }
                        }

                        if(index > farthest) {
                            farthest = index;
                            pos = j;
                        }
                    }
                }

                frames[pos] = pages[i];
                faults++;
            }
        }

        printf("\nOptimal Page Faults = %d\n", faults);
        break;
    }

    default:
        printf("Invalid Choice\n");
    }

    return 0;
}
