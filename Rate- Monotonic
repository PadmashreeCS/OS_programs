#include <stdio.h>

int gcd(int a, int b)
{
    while(b != 0)
    {
        int temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

int lcm(int a, int b)
{
    return (a * b) / gcd(a, b);
}

int main()
{
    int n;

    printf("Enter number of tasks: ");
    scanf("%d", &n);

    int exec[n], period[n];
    int remaining[n];
    int release[n];

    // Input Tasks
    for(int i = 0; i < n; i++)
    {
        printf("\nTask T%d\n", i + 1);

        printf("Execution Time: ");
        scanf("%d", &exec[i]);

        printf("Period: ");
        scanf("%d", &period[i]);

        remaining[i] = 0;
        release[i] = 0;
    }

    // Calculate Hyperperiod
    int hyper = period[0];

    for(int i = 1; i < n; i++)
    {
        hyper = lcm(hyper, period[i]);
    }

    printf("\nHyperperiod = %d\n", hyper);

    // Calculate CPU Utilization
    float utilization = 0;

    for(int i = 0; i < n; i++)
    {
        utilization += (float)exec[i] / period[i];
    }

    printf("CPU Utilization = %.2f\n", utilization);
    printf("CPU Utilization = %.2f%%\n", utilization * 100);

    printf("\nPriority Order (Smaller Period = Higher Priority)\n");

    for(int p = 1; p <= n; p++)
    {
        int min = -1;

        for(int i = 0; i < n; i++)
        {
            int alreadyPrinted = 0;

            for(int j = 0; j < p - 1; j++)
            {
                // nothing needed here
            }

            if(min == -1 || period[i] < period[min])
            {
                int used = 0;

                for(int k = 0; k < i; k++)
                {
                    if(period[k] == period[i] && k < i)
                    {
                        used = 1;
                    }
                }

                if(!used)
                    min = i;
            }
        }
    }

    printf("\nGantt Chart:\n");

    for(int time = 0; time < hyper; time++)
    {
        // Release tasks at their period
        for(int i = 0; i < n; i++)
        {
            if(time == release[i])
            {
                remaining[i] = exec[i];
                release[i] += period[i];
            }
        }

        int selected = -1;

        // Select task with smallest period
        for(int i = 0; i < n; i++)
        {
            if(remaining[i] > 0)
            {
                if(selected == -1 ||
                   period[i] < period[selected])
                {
                    selected = i;
                }
            }
        }

        if(selected == -1)
        {
            printf("| Idle ");
        }
        else
        {
            printf("| T%d ", selected + 1);
            remaining[selected]--;
        }
    }

    printf("|\n\n");

    printf("Time : ");
    for(int i = 0; i <= hyper; i++)
    {
        printf("%d ", i);
    }

    printf("\n");

    return 0;
}
