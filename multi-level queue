#include <stdio.h>

int main()
{
    int ns, nu;
    int bt[20], wt[20], tat[20];
    int pid[20];

    printf("Enter number of System Processes: ");
    scanf("%d", &ns);

    printf("\nEnter Burst Time for System Processes:\n");
    for(int i = 0; i < ns; i++)
    {
        pid[i] = i + 1;
        printf("P%d: ", pid[i]);
        scanf("%d", &bt[i]);
    }

    printf("\nEnter number of User Processes: ");
    scanf("%d", &nu);

    printf("\nEnter Burst Time for User Processes:\n");
    for(int i = 0; i < nu; i++)
    {
        pid[ns + i] = ns + i + 1;
        printf("P%d: ", pid[ns + i]);
        scanf("%d", &bt[ns + i]);
    }

    int total = ns + nu;

    // FCFS Scheduling
    wt[0] = 0;

    for(int i = 1; i < total; i++)
    {
        wt[i] = wt[i - 1] + bt[i - 1];
    }

    for(int i = 0; i < total; i++)
    {
        tat[i] = wt[i] + bt[i];
    }

    printf("\n===== Execution Order =====\n");

    printf("\nSystem Processes (Higher Priority):\n");
    for(int i = 0; i < ns; i++)
    {
        printf("P%d ", pid[i]);
    }

    printf("\n\nUser Processes (Lower Priority):\n");
    for(int i = ns; i < total; i++)
    {
        printf("P%d ", pid[i]);
    }

    printf("\n\n===== Result Table =====\n");
    printf("\nPID\tBT\tWT\tTAT\n");

    for(int i = 0; i < total; i++)
    {
        printf("P%d\t%d\t%d\t%d\n",
               pid[i], bt[i], wt[i], tat[i]);
    }

    return 0;
}
