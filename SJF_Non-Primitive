#include <stdio.h>

int main() {
    int n, at[10], bt[10], ct[10], tat[10], wt[10], done[10] = {0};
    float avg_tat = 0, avg_wt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(int i=0;i<n;i++){
        printf("P%d Arrival Time: ", i+1);
        scanf("%d",&at[i]);
        printf("P%d Burst Time: ", i+1);
        scanf("%d",&bt[i]);
    }

    int time = 0, completed = 0;
    while(completed < n){
        int idx = -1, smallest = 100000;  // renamed from 'earliest'

        for(int i=0;i<n;i++){
            if(!done[i] && at[i]<=time){
                if(at[i] < smallest){
                    smallest = at[i];
                    idx = i;
                }
            }
        }

        if(idx == -1){ time++; continue; } // CPU idle

        ct[idx] = time + bt[idx];
        tat[idx] = ct[idx] - at[idx];
        wt[idx] = tat[idx] - bt[idx];

        time = ct[idx];
        done[idx] = 1;
        completed++;

        avg_tat += tat[idx];
        avg_wt += wt[idx];
    }

    printf("\nP\tAT\tBT\tCT\tTAT\tWT\n");
    for(int i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", i+1, at[i], bt[i], ct[i], tat[i], wt[i]);

    printf("\nAverage TAT = %.2f", avg_tat/n);
    printf("\nAverage WT = %.2f\n", avg_wt/n);

    return 0;
}
