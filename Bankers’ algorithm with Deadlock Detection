#include <stdio.h>

int main()
{
    int n, m;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter number of resource types: ");
    scanf("%d", &m);

    int alloc[n][m];
    int request[n][m];
    int avail[m];

    // Input Allocation Matrix
    printf("\nEnter Allocation Matrix:\n");
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            scanf("%d", &alloc[i][j]);
        }
    }

    // Input Request Matrix
    printf("\nEnter Request Matrix:\n");
    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < m; j++)
        {
            scanf("%d", &request[i][j]);
        }
    }

    // Input Available Matrix
    printf("\nEnter Available Resources:\n");
    for(int i = 0; i < m; i++)
    {
        scanf("%d", &avail[i]);
    }

    printf("\nAvailable Matrix:\n");
    for(int i = 0; i < m; i++)
    {
        printf("%d ", avail[i]);
    }
    printf("\n");

    int finish[n];

    for(int i = 0; i < n; i++)
    {
        finish[i] = 0;
    }

    int count = 0;

    while(count < n)
    {
        int found = 0;

        for(int i = 0; i < n; i++)
        {
            if(finish[i] == 0)
            {
                int possible = 1;

                for(int j = 0; j < m; j++)
                {
                    if(request[i][j] > avail[j])
                    {
                        possible = 0;
                        break;
                    }
                }

                if(possible)
                {
                    printf("\nProcess P%d can complete\n", i);

                    printf("Available Before Execution: ");
                    for(int k = 0; k < m; k++)
                    {
                        printf("%d ", avail[k]);
                    }
                    printf("\n");

                    for(int j = 0; j < m; j++)
                    {
                        avail[j] += alloc[i][j];
                    }

                    printf("Available After Execution : ");
                    for(int k = 0; k < m; k++)
                    {
                        printf("%d ", avail[k]);
                    }
                    printf("\n");

                    finish[i] = 1;
                    count++;
                    found = 1;
                }
            }
        }

        if(found == 0)
        {
            break;
        }
    }

    if(count == n)
    {
        printf("\nNo Deadlock Detected\n");
    }
    else
    {
        printf("\nDeadlock Detected\n");

        printf("Processes involved in deadlock: ");
        for(int i = 0; i < n; i++)
        {
            if(finish[i] == 0)
            {
                printf("P%d ", i);
            }
        }
        printf("\n");
    }

    return 0;
}
