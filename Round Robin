#include <stdio.h>

int main() {
    int n, tq;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    int at[n], bt[n], rt[n];
    int ct[n], tat[n], wt[n];
    int q[100], front = 0, rear = 0;
    int visited[n];

    for (int i = 0; i < n; i++) {
        printf("\nProcess P%d\n", i + 1);

        printf("Arrival Time: ");
        scanf("%d", &at[i]);

        printf("Burst Time: ");
        scanf("%d", &bt[i]);

        rt[i] = bt[i];
        visited[i] = 0;
        ct[i] = tat[i] = wt[i] = 0;
    }

    int curr_time = 0;
    int completed = 0;

    while (completed < n) {

        for (int i = 0; i < n; i++) {
            if (at[i] <= curr_time && visited[i] == 0) {
                q[rear++] = i;
                visited[i] = 1;
            }
        }

        if (front == rear) { // idel time, ex: no processor at time = 0
            curr_time++;
            continue;
        }

        int p = q[front++]; // ready queue travels 

        if (rt[p] > tq) {
            curr_time += tq;
            rt[p] -= tq;

            for (int i = 0; i < n; i++) { // check any processor came in between, while runing the process
                if (at[i] <= curr_time && visited[i] == 0) {
                    q[rear++] = i;
                    visited[i] = 1;
                }
            }

            q[rear++] = p; // then add the unfinshed process at last 
        }
        else {
            curr_time += rt[p];
            rt[p] = 0;

            ct[p] = curr_time;
            tat[p] = ct[p] - at[p];
            wt[p] = tat[p] - bt[p];

            completed++;
        }
    }

    float avg_tat = 0, avg_wt = 0;

    printf("\nP\tAT\tBT\tCT\tTAT\tWT\n");

    for (int i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1, at[i], bt[i], ct[i], tat[i], wt[i]);

        avg_tat += tat[i];
        avg_wt += wt[i];
    }

    printf("\nAverage TAT = %.2f", avg_tat / n);
    printf("\nAverage WT = %.2f\n", avg_wt / n);

    return 0;
}
