#include <stdio.h>

int main()
{
    int n;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int burst[n], weight[n];

    // Input
    for(int i = 0; i < n; i++)
    {
        printf("\nProcess %d\n", i + 1);

        printf("Burst Time: ");
        scanf("%d", &burst[i]);

        printf("Weight: ");
        scanf("%d", &weight[i]);
    }

    printf("\nExecution Order:\n");

    int done;
    // P1 Burst = 6 Weight = 3 , P2 Burst = 6 Weight = 1 >> 1st-> p1 p1 p1 p2 , 2nd-> p1 p1 p1 

    do
    {
        done = 1;

        for(int i = 0; i < n; i++)
        {
            for(int w = 1; w <= weight[i]; w++)
            {
                if(burst[i] > 0)
                {
                    printf("P%d ", i + 1);
                    burst[i]--;   // Execute 1 unit of process
                    done = 0;
                }
            }
        }

    } while(!done);   // Continue until all processes finish

    printf("\n");

    return 0;
}
